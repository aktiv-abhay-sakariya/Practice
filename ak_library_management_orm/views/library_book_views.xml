<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- inherit Form View: make isbn field is readonly-->
    <record id='library_book_view_form_inherit_orm' model='ir.ui.view'>
        <field name="name">library.book.view.form.inherit.orm</field>
        <field name="model">library.book</field>
        <field name="inherit_id"
               ref="ak_library_management.library_book_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='isbn']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            
            <xpath expr="//header" position="inside">
                    <button name="find_book"
                        type="object"
                        string="Email"
                        class="btn-primary"/>
            </xpath>

        </field>
    </record>
</odoo>
