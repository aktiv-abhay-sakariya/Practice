<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id='user_access_group' model='res.groups'>
        <field name="name">User</field>
    </record>
    
    <record id='manager_access_group' model='res.groups'>
        <field name="name">Manager</field>
        <field name="implied_ids" eval="[(4, ref('user_access_group'))]"/>
    </record>

    <record id="user_rules" model="ir.rule">
        <field name="name">user author view</field>
        <field name="model_id" ref="ak_library_management_orm.model_author_author"></field>
        <field name="domain_force">[('author_status','=','active')]</field>
        <field name="groups" eval="[(4, ref('user_access_group'))]"></field>
    </record>

    <record id="manager_rules" model="ir.rule">
        <field name="name">manager author view</field>
        <field name="model_id" ref="ak_library_management_orm.model_author_author"></field>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('manager_access_group'))]"></field>
    </record>
</odoo>