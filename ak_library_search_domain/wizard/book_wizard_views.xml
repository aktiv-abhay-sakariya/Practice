<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_sale_book_wizard" model="ir.ui.view">
        <field name="name">sale.book.wizard.form</field>
        <field name="model">sale.book.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Books">
                <sheet>
                    <group>
                        <field name="line_ids">
                            <list editable="bottom"> 
                                <field name="product_id"/>
                                <field name="quantity"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_add_books"
                            type="object"
                            string="Add to Order"
                            class="btn-primary"
                            data-hotkey="q"/>

                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
