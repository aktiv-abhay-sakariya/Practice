<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_form_view_orm" model="ir.ui.view">
        <field name="name">sale.order.form.view.orm</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
        
            <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                <attribute name='invisible'>approve_need == True</attribute>
            </xpath>

            <xpath expr="//field[@name='pricelist_id']" position="after">
                <field name="approve_need" invisible="1"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <button string="Approve"
                name="action_approve"
                type="object"
                invisible="approve_need == False"/>
                
                <button string="Reject"
                name="action_reject"
                type="object"
                invisible="approve_need == False"/>
            </xpath>
        </field>
    </record>

</odoo>
