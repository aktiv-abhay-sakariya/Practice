<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- inherit Form View: make isbn field is readonly-->
    <record id='library_book_view_form_inherit_orm' model='ir.ui.view'>
        <field name="name">library.book.view.form.inherit.orm</field>
        <field name="model">library.book</field>
        <field name="inherit_id"
               ref="ak_library_management_enhancement.library_book_view_form_inherit"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name='action_product_view'
                        type="object"
                        class="oe_stat_button"
                        icon="fa-cube"
                        invisible="is_product_created == False">
                    <span>Product</span>
                    </button>
                </div>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="create_product"
                    type="object"
                    string="Create Product"
                    class="btn-primary"
                    invisible="is_product_created == True"/>
                <button name="send_email"
                    type="object"
                    string="Email"
                    class="btn-primary"/>
            </xpath>

            <xpath expr="//field[@name='isbn']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>
</odoo>
