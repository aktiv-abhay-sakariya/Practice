<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for library book-->
        <record id="library_book_seq" model="ir.sequence">
            <field name="name">Book Sequence</field>
            <field name="code">library.book</field>
            <field name="prefix">BK-%(year)s-%(month)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
