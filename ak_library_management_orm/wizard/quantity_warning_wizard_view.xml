<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_quantity_warning_form_view" model="ir.ui.view">
        <field name="name">product.quantity.warning.form.view</field>
        <field name="model">product.quantity.wizard</field>
        <field name="arch" type="xml">
            <form>
                <p>Approval needed! The following books have low stock: </p>
                <field name="message" readonly="1"/>
                <footer>
                    <button name="action_done" string="Confirm" type="object" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
